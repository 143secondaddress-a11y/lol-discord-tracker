# Riot Games API キー
# https://developer.riotgames.com で取得（開発用は24時間更新）
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Riot ID (# より前がゲーム名、後ろがタグライン)
# 例: "Faker#KR1" なら GAME_NAME=Faker, TAG_LINE=KR1
GAME_NAME=あなたのゲーム名
TAG_LINE=JP1

# Discord Webhook URL
# Discordサーバー設定 → 連携サービス → ウェブフック → 新しいウェブフック
DISCORD_WEBHOOK=https://discord.com/api/webhooks/xxxxxxxxxx/xxxxxxxxxxxxxxxx
